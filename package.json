{
  "scripts": {
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:backend": "node backend/src/index.js",
    "start": "concurrently \"npm start --prefix backend\" \"npm run build --prefix frontend && npm run preview --prefix frontend\""
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.2",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.2"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.100.0",
    "lucide-react": "^1.6.0"
  }
}
